# Password for the read-only DB user (set in backend/db/init scripts)
FABRIQ_DB_READONLY_PASSWORD=change-me-in-prod
FABRIQ_DATABASE_URL=postgresql://fabriq_readonly:${FABRIQ_DB_READONLY_PASSWORD}@127.0.0.1:5432/fabriq
FABRIQ_LLM_PROVIDER=disabled
FABRIQ_OLLAMA_URL=http://127.0.0.1:11434
FABRIQ_OLLAMA_MODEL=llama3.1
FABRIQ_LLM_TIMEOUT_SECONDS=60

# Auth JWT (v0.3.0)
# Generate a hash with: python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt(12)).decode())"
FABRIQ_JWT_SECRET=changeme-in-prod-use-a-long-random-string
FABRIQ_JWT_EXPIRE_MINUTES=60
# Format: email:bcrypt_hash:tenant_id:role,email2:bcrypt_hash2:tenant_id2:role2
FABRIQ_USERS=admin@fabriq.io:$2b$12$PLACEHOLDER_REPLACE_ME:tenant_demo:admin

# SMTP optionnel pour notifications alertes (v0.5.0) — laisser vide pour désactiver
FABRIQ_SMTP_HOST=
FABRIQ_SMTP_PORT=587
FABRIQ_SMTP_USER=
FABRIQ_SMTP_PASS=
FABRIQ_ALERT_FROM_EMAIL=fabriq-alerts@votredomaine.com

# Slack Incoming Webhook global (v0.8.0) — optionnel, laisser vide pour désactiver
# Crée une app Slack sur https://api.slack.com/apps → "Incoming Webhooks"
FABRIQ_SLACK_WEBHOOK=

# SSO OIDC optionnel (v0.14) — laisser vide pour desactiver (login local FABRIQ_USERS)
# Avec le Keycloak du docker-compose : issuer http://localhost:8180/realms/fabriq
FABRIQ_OIDC_ISSUER=
FABRIQ_OIDC_CLIENT_ID=
FABRIQ_OIDC_CLIENT_SECRET=
FABRIQ_OIDC_REDIRECT_URL=http://localhost:8000/api/auth/oidc/callback
# Base interne si le backend joint le fournisseur par un autre nom que l'issuer
# public (Docker : http://keycloak:8080/realms/fabriq)
FABRIQ_OIDC_INTERNAL_BASE=
# URL du frontend vers laquelle rediriger apres le callback
FABRIQ_FRONTEND_URL=http://localhost:5173
